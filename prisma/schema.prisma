generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String       @id @default(cuid())
  email     String       @unique
  name      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  predictions Prediction[]
}

model Dataset {
  id        String   @id @default(cuid())
  name      String
  filename  String
  rows      Int
  columns   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  predictions Prediction[]
}

model Prediction {
  id           String   @id @default(cuid())
  model        String
  confidence   Float
  predictions  String
  statistics   String
  datasetId    String?
  userId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  dataset      Dataset? @relation(fields: [datasetId], references: [id])
  user         User?    @relation(fields: [userId], references: [id])
}

model ModelMetrics {
  id           String   @id @default(cuid())
  modelName    String
  accuracy     Float
  precision    Float
  recall       Float
  f1Score      Float
  trainingTime Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
